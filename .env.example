# ─────────────────────────────────────────────────────────────────────────────
# Fichier .env de production — copier en .env et remplir les vraies valeurs
# NE JAMAIS committer le fichier .env dans git
# ─────────────────────────────────────────────────────────────────────────────

# ─── Base de données MySQL ────────────────────────────────────────────────────
DB_NAME=marsai
DB_USER=root
DB_PASSWORD=change-this-strong-password

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-very-long-random-secret

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ─── Scaleway S3 ─────────────────────────────────────────────────────────────
SCALEWAY_ACCESS_KEY=
SCALEWAY_SECRET_KEY=
SCALEWAY_ENDPOINT=https://s3.fr-par.scw.cloud
SCALEWAY_BUCKET_NAME=tln
SCALEWAY_REGION=fr-par
SCALEWAY_FOLDER=grp1

# ─── Email (Brevo) ───────────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# ─── LiveKit (vocal jury) ────────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://marsai.lightchurch.fr
