      "id": 38, "type": "table", "title": "Activité jury — détail",
      "gridPos": { "x": 14, "y": 75, "w": 10, "h": 10 },
      "datasource": { "type": "mysql", "uid": "marsai-mysql" },
      "options": { "showHeader": true, "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Évaluations" }, "properties": [{ "id": "custom.displayMode", "value": "lcd-gauge" }, { "id": "min", "value": 0 }, { "id": "color", "value": { "mode": "thresholds" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 5 }, { "color": "gold", "value": 20 }] } }] },
          { "matcher": { "id": "byName", "options": "Rôle" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "mappings", "value": [{ "type": "value", "options": { "admin": { "color": "#F2495C", "text": "Admin" } } }, { "type": "value", "options": { "moderateur": { "color": "#FF9830", "text": "Modérateur" } } }, { "type": "value", "options": { "jury": { "color": "#5794F2", "text": "Jury" } } }] }] }
        ]
      },
      "targets": [{ "rawQuery": true, "rawSql": "SELECT CONCAT(j.first_name, ' ', j.last_name) AS Juré, j.role AS Rôle, COUNT(jfc.id) AS Évaluations, COUNT(dm.id) AS Messages, CASE WHEN j.is_active = 1 THEN '✅' ELSE '❌' END AS Actif FROM jury j LEFT JOIN jury_film_commentary jfc ON j.id = jfc.jury_id LEFT JOIN discussion_message dm ON j.id = dm.jury_id GROUP BY j.id, j.first_name, j.last_name, j.role, j.is_active ORDER BY Évaluations DESC", "format": "table", "refId": "A" }]
