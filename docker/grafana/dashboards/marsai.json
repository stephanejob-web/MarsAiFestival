      "targets": [{ "rawQuery": true, "rawSql": "SELECT f.original_title AS Titre, CONCAT(r.first_name, ' ', r.last_name) AS Réalisateur, r.country AS Pays, f.language AS Langue, f.ia_class AS IA, f.statut AS Statut, f.duration AS Durée, DATE_FORMAT(f.created_at, '%d/%m/%Y') AS Date FROM film f INNER JOIN realisator r ON f.realisator_id = r.id ORDER BY f.created_at DESC LIMIT 20", "format": "table", "refId": "A" }]
