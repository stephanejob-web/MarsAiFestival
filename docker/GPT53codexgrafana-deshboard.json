    {
      "id": 22,
      "type": "table",
      "title": "Volume des votes par jury",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT CONCAT(j.first_name, ' ', j.last_name) AS jury, COUNT(*) AS total_votes, SUM(CASE WHEN c.decision = 'valide' THEN 1 ELSE 0 END) AS valide, SUM(CASE WHEN c.decision = 'arevoir' THEN 1 ELSE 0 END) AS arevoir, SUM(CASE WHEN c.decision = 'refuse' THEN 1 ELSE 0 END) AS refuse, SUM(CASE WHEN c.decision = 'in_discussion' THEN 1 ELSE 0 END) AS in_discussion, SUM(CASE WHEN c.decision IS NULL THEN 1 ELSE 0 END) AS no_decision FROM jury_film_commentary c JOIN jury j ON j.id = c.jury_id GROUP BY j.id, jury ORDER BY total_votes DESC"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 23,
      "type": "table",
      "title": "Films avec desaccord jury",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT f.id, f.original_title, COUNT(*) AS total_votes, COUNT(DISTINCT COALESCE(c.decision, 'no_decision')) AS decisions_distinctes, GROUP_CONCAT(DISTINCT COALESCE(c.decision, 'no_decision') ORDER BY COALESCE(c.decision, 'no_decision') SEPARATOR ', ') AS decisions FROM jury_film_commentary c JOIN film f ON f.id = c.film_id GROUP BY f.id, f.original_title HAVING COUNT(DISTINCT COALESCE(c.decision, 'no_decision')) > 1 ORDER BY decisions_distinctes DESC, total_votes DESC LIMIT 50"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 24,
      "type": "table",
      "title": "Suivi de couverture des films",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT metric, value FROM (SELECT 'Films en attente de revue' AS metric, COUNT(*) AS value FROM film WHERE statut IN ('to_review','arevoir','in_discussion','asked_to_modify','soumis') UNION ALL SELECT 'Films sans assignation', COUNT(*) FROM film f LEFT JOIN jury_film_assignment a ON a.film_id = f.id WHERE a.id IS NULL UNION ALL SELECT 'Films sans vote jury', COUNT(*) FROM film f LEFT JOIN jury_film_commentary c ON c.film_id = f.id WHERE c.id IS NULL UNION ALL SELECT 'Films assignes sans vote', COUNT(*) FROM film f WHERE EXISTS (SELECT 1 FROM jury_film_assignment a WHERE a.film_id = f.id) AND NOT EXISTS (SELECT 1 FROM jury_film_commentary c WHERE c.film_id = f.id)) x ORDER BY value DESC"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
