          "rawSql": "SELECT COALESCE(ROUND(100 * (SELECT COUNT(DISTINCT film_id) FROM jury_film_commentary) / NULLIF(COUNT(*), 0), 1), 0) AS value FROM film"
        }
      ],
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
