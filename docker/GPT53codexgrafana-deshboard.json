    {
      "id": 17,
      "type": "table",
      "title": "Films en attente a prioriser",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT f.id, f.original_title, f.statut, f.created_at, TIMESTAMPDIFF(DAY, f.created_at, NOW()) AS jours_depuis_depot, COALESCE(a.assignment_count, 0) AS assignments, COALESCE(v.vote_count, 0) AS votes FROM film f LEFT JOIN (SELECT film_id, COUNT(*) AS assignment_count FROM jury_film_assignment GROUP BY film_id) a ON a.film_id = f.id LEFT JOIN (SELECT film_id, COUNT(*) AS vote_count FROM jury_film_commentary GROUP BY film_id) v ON v.film_id = f.id WHERE f.statut IN ('to_review','arevoir','in_discussion','asked_to_modify','soumis') ORDER BY jours_depuis_depot DESC, votes ASC LIMIT 100"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
