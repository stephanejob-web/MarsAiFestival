      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 42 },
      "id": 31,
      "options": {
        "barRadius": 0.15,
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Messages par film (top discussions)",
      "type": "barchart",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT f.original_title AS \"Film\", COUNT(d.id) AS \"Messages\" FROM film f INNER JOIN discussion_message d ON d.film_id = f.id GROUP BY f.id ORDER BY COUNT(d.id) DESC LIMIT 10", "format": "table", "refId": "A" }]
    },

    {
