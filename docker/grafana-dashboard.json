      },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT CONCAT(j.first_name,' ',j.last_name) AS Juré, COUNT(CASE WHEN jfc.decision='valide' THEN 1 END) AS Validé, COUNT(CASE WHEN jfc.decision='arevoir' THEN 1 END) AS `À revoir`, COUNT(CASE WHEN jfc.decision='refuse' THEN 1 END) AS Refusé, COUNT(CASE WHEN jfc.decision='in_discussion' THEN 1 END) AS `En discussion` FROM jury j LEFT JOIN jury_film_commentary jfc ON jfc.jury_id=j.id WHERE j.role='jury' GROUP BY j.id ORDER BY (COUNT(CASE WHEN jfc.decision='valide' THEN 1 END)+COUNT(CASE WHEN jfc.decision='arevoir' THEN 1 END)+COUNT(CASE WHEN jfc.decision='refuse' THEN 1 END)) DESC", "format": "table", "refId": "A" }] },

