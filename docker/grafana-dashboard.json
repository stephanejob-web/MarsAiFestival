      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS \"Jurés\" FROM jury WHERE role = 'jury' AND is_active = 1", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#34D399" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#34D399", "value": null }] },
