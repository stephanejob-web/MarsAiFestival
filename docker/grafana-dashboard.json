      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 202,
      "title": "🌍  Géographie & Tendances",
      "type": "row"
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "unit": "short", "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 10, "x": 0, "y": 25 },
      "id": 20,
      "options": {
        "barRadius": 0.15,
        "barWidth": 0.65,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Top 10 pays — Films déposés",
      "type": "barchart",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT r.country AS \"Pays\", COUNT(f.id) AS \"Films\" FROM film f JOIN realisator r ON r.id = f.realisator_id GROUP BY r.country ORDER BY COUNT(f.id) DESC LIMIT 10", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#4EFFCE" },
          "custom": { "fillOpacity": 15, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5, "showPoints": "auto", "spanNulls": true },
          "unit": "short", "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 14, "x": 10, "y": 25 },
      "id": 21,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
