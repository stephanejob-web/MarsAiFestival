        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#4EFFCE" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#4EFFCE", "value": null }] },
          "unit": "short",
          "decimals": 0
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "🎬  Films déposés",
      "type": "stat",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS \"Films\" FROM film", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
