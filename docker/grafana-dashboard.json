      "type": "stat",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS \"Tickets\" FROM ticket WHERE status = 'open'", "format": "table", "refId": "A" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 201,
      "title": "🎬  Analyse des films",
      "type": "row"
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } } }
      },
      "gridPos": { "h": 9, "w": 7, "x": 0, "y": 9 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Statut des films",
      "type": "piechart",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT statut AS \"Statut\", COUNT(*) AS \"Nombre\" FROM film GROUP BY statut ORDER BY COUNT(*) DESC", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } } }
      },
      "gridPos": { "h": 9, "w": 7, "x": 7, "y": 9 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "values": ["value", "percent"] },
        "pieType": "pie",
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Full IA vs Hybride",
      "type": "piechart",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT CASE ia_class WHEN 'full' THEN '🤖 Full IA' WHEN 'hybrid' THEN '🔀 Hybride' ELSE ia_class END AS \"Classe\", COUNT(*) AS \"Nombre\" FROM film GROUP BY ia_class", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#4EFFCE" },
          "custom": { "fillOpacity": 75, "lineWidth": 0 },
          "unit": "short", "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 9 },
      "id": 12,
      "options": {
        "barRadius": 0.15,
        "barWidth": 0.65,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelSpacing": 100
      },
      "title": "Outils IA les plus utilisés",
      "type": "barchart",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT 'IA Image' AS Outil, SUM(ia_image) AS Total FROM film UNION ALL SELECT 'IA Son', SUM(ia_son) FROM film UNION ALL SELECT 'IA Scénario', SUM(ia_scenario) FROM film UNION ALL SELECT 'IA Post-prod', SUM(ia_post) FROM film ORDER BY Total DESC", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#FF6B6B", "value": null }, { "color": "#FFD93D", "value": 30 }, { "color": "#34D399", "value": 60 }] },
          "unit": "percent",
          "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 18 },
      "id": 13,
      "options": {
        "minVizHeight": 75, "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Taux de validation",
      "type": "gauge",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT ROUND(COUNT(CASE WHEN statut IN ('valide','selectionne','finaliste') THEN 1 END) * 100.0 / COUNT(*), 1) AS \"Taux\" FROM film", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#FF6B6B", "value": null }, { "color": "#FFD93D", "value": 10 }, { "color": "#34D399", "value": 20 }] },
          "unit": "percent",
          "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 18 },
      "id": 14,
      "options": {
        "minVizHeight": 75, "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Taux de finalistes",
      "type": "gauge",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT ROUND(COUNT(CASE WHEN statut = 'finaliste' THEN 1 END) * 100.0 / COUNT(*), 1) AS \"Taux\" FROM film", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 70, "lineWidth": 0 },
          "unit": "short", "min": 0
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "id": 15,
      "options": {
        "barRadius": 0.15,
        "barWidth": 0.65,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Films par langue",
      "type": "barchart",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT language AS \"Langue\", COUNT(*) AS \"Films\" FROM film GROUP BY language ORDER BY COUNT(*) DESC LIMIT 10", "format": "table", "refId": "A" }]
    },

