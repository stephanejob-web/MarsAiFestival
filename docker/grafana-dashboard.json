          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "rawSql": "SELECT r.country AS \"Pays\", COUNT(f.id) AS \"Films\" FROM film f JOIN realisator r ON r.id = f.realisator_id GROUP BY r.country ORDER BY COUNT(f.id) DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
