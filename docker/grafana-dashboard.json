        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false },
        "content": "<div style=\"display:flex;align-items:center;justify-content:space-between;padding:8px 16px;background:linear-gradient(135deg,rgba(78,255,206,0.08) 0%,rgba(167,139,250,0.08) 100%);border-radius:8px;border:1px solid rgba(78,255,206,0.2)\">\n  <div>\n    <div style=\"font-size:22px;font-weight:900;letter-spacing:-0.03em;color:#fff\">mars<span style=\"color:#4EFFCE\">AI</span> Festival <span style=\"color:#FFD93D\">2026</span></div>\n    <div style=\"font-size:11px;color:rgba(255,255,255,0.4);letter-spacing:0.1em;text-transform:uppercase;margin-top:2px\">Tableau de bord — Administration & Suivi</div>\n  </div>\n  <div style=\"display:flex;gap:24px;font-size:11px;color:rgba(255,255,255,0.5)\">\n    <span>🎬 Festival de films IA</span>\n    <span>📊 Données en temps réel</span>\n    <span>🔄 Actualisation : 30s</span>\n  </div>\n</div>",
        "mode": "html"
      },
      "title": "",
      "transparent": true,
      "type": "text"
    },

    {
