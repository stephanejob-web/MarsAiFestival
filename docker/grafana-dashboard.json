      "title": "🎥  Réalisateurs",
      "type": "stat",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(DISTINCT realisator_id) AS \"Réalisateurs\" FROM film", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#FFD93D" },
