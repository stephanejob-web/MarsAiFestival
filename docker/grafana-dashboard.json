          { "matcher": { "id": "byName", "options": "Statut" }, "properties": [{ "id": "custom.width", "value": 130 }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "mappings", "value": [{ "options": { "finaliste": { "color": "#FFD93D", "index": 0, "text": "🏆 Finaliste" }, "selectionne": { "color": "#4EFFCE", "index": 1, "text": "⭐ Sélectionné" }, "valide": { "color": "#34D399", "index": 2, "text": "✅ Validé" }, "arevoir": { "color": "#60A5FA", "index": 3, "text": "🔄 À revoir" }, "in_discussion": { "color": "#A78BFA", "index": 4, "text": "💬 Discussion" }, "asked_to_modify": { "color": "#F97316", "index": 5, "text": "✏️ Modif" }, "to_review": { "color": "#6B7280", "index": 6, "text": "🔍 À examiner" }, "soumis": { "color": "#6B7280", "index": 7, "text": "📥 Soumis" }, "refuse": { "color": "#FF6B6B", "index": 8, "text": "❌ Refusé" } }, "type": "value" }] }] },
          { "matcher": { "id": "byName", "options": "IA" }, "properties": [{ "id": "custom.width", "value": 100 }, { "id": "mappings", "value": [{ "options": { "full": { "color": "#A78BFA", "index": 0, "text": "🤖 Full IA" }, "hybrid": { "color": "#F97316", "index": 1, "text": "🔀 Hybride" } }, "type": "value" }] }] },
          { "matcher": { "id": "byName", "options": "N° Dossier" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Durée (min)" }, "properties": [{ "id": "custom.width", "value": 100 }] }
        ]
      },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT f.dossier_num AS `N° Dossier`, f.original_title AS Titre, CONCAT(r.first_name,' ',r.last_name) AS Réalisateur, r.country AS Pays, f.language AS Langue, f.ia_class AS IA, ROUND(f.duration/60.0,1) AS `Durée (min)`, f.statut AS Statut, DATE_FORMAT(f.created_at,'%d/%m/%Y') AS `Déposé le` FROM film f JOIN realisator r ON r.id=f.realisator_id ORDER BY f.created_at DESC", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 12, "w": 9, "x": 15, "y": 85 }, "id": 91, "type": "table",
      "title": "Réalisateurs — Engagement & Profil",
      "options": { "cellHeight": "sm", "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Films" }] },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "auto", "cellOptions": { "type": "auto" } }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Newsletter" }, "properties": [{ "id": "custom.width", "value": 90 }, { "id": "mappings", "value": [{ "options": { "1": { "color": "#34D399", "index": 0, "text": "✅" }, "0": { "color": "#6B7280", "index": 1, "text": "Non" } }, "type": "value" }] }] },
          { "matcher": { "id": "byName", "options": "Films" }, "properties": [{ "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "gauge" } }, { "id": "custom.width", "value": 100 }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "#4EFFCE", "value": null }, { "color": "#FFD93D", "value": 2 }, { "color": "#F97316", "value": 4 }] } }] },
          { "matcher": { "id": "byName", "options": "Réseaux" }, "properties": [{ "id": "custom.width", "value": 80 }] }
        ]
      },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT CONCAT(r.first_name,' ',r.last_name) AS Réalisateur, r.country AS Pays, r.newsletter AS Newsletter, COUNT(f.id) AS Films, (CASE WHEN r.youtube IS NOT NULL AND r.youtube!='' THEN 1 ELSE 0 END + CASE WHEN r.instagram IS NOT NULL AND r.instagram!='' THEN 1 ELSE 0 END + CASE WHEN r.linkedin IS NOT NULL AND r.linkedin!='' THEN 1 ELSE 0 END + CASE WHEN r.facebook IS NOT NULL AND r.facebook!='' THEN 1 ELSE 0 END + CASE WHEN r.xtwitter IS NOT NULL AND r.xtwitter!='' THEN 1 ELSE 0 END) AS Réseaux, DATE_FORMAT(MAX(f.created_at),'%d/%m/%Y') AS `Dernier dépôt` FROM realisator r JOIN film f ON f.realisator_id=r.id GROUP BY r.id ORDER BY COUNT(f.id) DESC", "format": "table", "refId": "A" }] }

  ]
}
