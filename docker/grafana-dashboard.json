        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "rawSql": "SELECT f.original_title AS \"Film\", COUNT(d.id) AS \"Messages\" FROM film f LEFT JOIN discussion_message d ON d.film_id = f.id GROUP BY f.id HAVING COUNT(d.id) > 0 ORDER BY COUNT(d.id) DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
