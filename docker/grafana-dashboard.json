      "type": "table",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "rawSql": "SELECT CONCAT(j.first_name, ' ', j.last_name) AS \"Juré\", f.original_title AS \"Film\", t.type AS \"Type\", t.status AS \"Statut\", DATE_FORMAT(t.created_at, '%d/%m/%Y') AS \"Créé le\" FROM ticket t JOIN jury j ON j.id = t.jury_id JOIN film f ON f.id = t.film_id ORDER BY t.created_at DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
