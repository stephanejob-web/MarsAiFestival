      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT DATE_FORMAT(created_at, '%Y-%m-%d') AS time, COUNT(*) AS \"Films déposés\" FROM film GROUP BY DATE_FORMAT(created_at, '%Y-%m-%d') ORDER BY time", "format": "time_series", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#A78BFA" },
          "custom": { "fillOpacity": 12, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 4, "showPoints": "auto", "spanNulls": true },
          "unit": "short", "min": 0
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 34 },
      "id": 22,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "💬  Activité des discussions dans le temps",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT DATE_FORMAT(sent_at, '%Y-%m-%d') AS time, COUNT(*) AS \"Messages\" FROM discussion_message GROUP BY DATE_FORMAT(sent_at, '%Y-%m-%d') ORDER BY time", "format": "time_series", "refId": "A" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 203,
      "title": "⚖️  Activité du jury",
      "type": "row"
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Films assignés" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "gauge" } },
              { "id": "custom.width", "value": 180 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "#34D399", "value": null }, { "color": "#FFD93D", "value": 5 }, { "color": "#FF6B6B", "value": 12 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Rôle" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [{ "options": { "admin": { "color": "#FF6B6B", "index": 0, "text": "👑 Admin" }, "jury": { "color": "#4EFFCE", "index": 1, "text": "⚖️ Jury" }, "moderateur": { "color": "#A78BFA", "index": 2, "text": "🛡️ Modo" } }, "type": "value" }] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Actif" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "mappings", "value": [{ "options": { "1": { "color": "#34D399", "index": 0, "text": "✅" }, "0": { "color": "#FF6B6B", "index": 1, "text": "❌" } }, "type": "value" }] }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 42 },
      "id": 30,
      "options": {
        "cellHeight": "md",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Films assignés" }]
      },
      "title": "Tableau du jury — Films assignés",
      "type": "table",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT CONCAT(j.first_name, ' ', j.last_name) AS \"Nom\", j.role AS \"Rôle\", j.is_active AS \"Actif\", j.email AS \"Email\", COUNT(DISTINCT a.film_id) AS \"Films assignés\", DATE_FORMAT(j.created_at, '%d/%m/%Y') AS \"Inscrit le\" FROM jury j LEFT JOIN jury_film_assignment a ON a.jury_id = j.id GROUP BY j.id ORDER BY COUNT(DISTINCT a.film_id) DESC", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
