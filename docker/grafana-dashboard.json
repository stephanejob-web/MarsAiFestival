          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Statut" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-text" } }, { "id": "mappings", "value": [{ "options": { "open": { "color": "red", "index": 0, "text": "🔴 open" }, "in_progress": { "color": "yellow", "index": 1, "text": "🟡 en cours" }, "resolved": { "color": "green", "index": 2, "text": "🟢 résolu" }, "rejected": { "color": "blue", "index": 3, "text": "⚪ rejeté" } }, "type": "value" }] }] }
