      "title": "✅  Films validés",
      "type": "stat",
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS \"Validés\" FROM film WHERE statut IN ('valide','selectionne','finaliste')", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#A78BFA" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#A78BFA", "value": null }] },
          "unit": "short", "decimals": 0
        }
