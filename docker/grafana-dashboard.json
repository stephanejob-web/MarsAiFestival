      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "rawSql": "SELECT CONCAT(j.first_name, ' ', j.last_name) AS \"Juré\", j.email AS \"Email\", COUNT(a.film_id) AS \"Films assignés\" FROM jury j LEFT JOIN jury_film_assignment a ON a.jury_id = j.id WHERE j.role = 'jury' GROUP BY j.id ORDER BY COUNT(a.film_id) DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },

