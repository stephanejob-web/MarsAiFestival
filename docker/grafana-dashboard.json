{
  "__inputs": [{ "name": "DS_MYSQL", "label": "MySQL — MarsAI", "type": "datasource", "pluginId": "mysql", "pluginName": "MySQL" }],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "mysql", "name": "MySQL", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["marsai", "festival", "2026"],
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "Europe/Paris",
  "title": "🎬  MarsAI Festival 2026 — Dashboard Pro",
  "uid": "marsai-festival-v3",
  "version": 3,
  "panels": [

    {
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 999, "type": "text", "title": "", "transparent": true,
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;align-items:center;justify-content:space-between;padding:12px 24px;background:linear-gradient(135deg,rgba(78,255,206,0.1) 0%,rgba(167,139,250,0.1) 50%,rgba(255,107,107,0.08) 100%);border-radius:12px;border:1px solid rgba(78,255,206,0.25);height:100%\">\n  <div style=\"display:flex;align-items:center;gap:20px\">\n    <div style=\"width:48px;height:48px;background:linear-gradient(135deg,#4EFFCE,#A78BFA);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px\">🎬</div>\n    <div>\n      <div style=\"font-size:26px;font-weight:900;letter-spacing:-0.03em;color:#fff;line-height:1\">mars<span style=\"color:#4EFFCE\">AI</span> Festival <span style=\"color:#FFD93D\">2026</span></div>\n      <div style=\"font-size:11px;color:rgba(255,255,255,0.45);letter-spacing:0.12em;text-transform:uppercase;margin-top:4px\">Tableau de bord administrateur — Données en temps réel</div>\n    </div>\n  </div>\n  <div style=\"display:flex;gap:32px\">\n    <div style=\"text-align:center\"><div style=\"font-size:10px;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em\">Actualisation</div><div style=\"color:#4EFFCE;font-weight:700;font-size:14px\">30s</div></div>\n    <div style=\"text-align:center\"><div style=\"font-size:10px;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em\">Fuseau</div><div style=\"color:#FFD93D;font-weight:700;font-size:14px\">Paris</div></div>\n    <div style=\"text-align:center\"><div style=\"font-size:10px;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em\">Version</div><div style=\"color:#A78BFA;font-weight:700;font-size:14px\">v3.0</div></div>\n  </div>\n</div>"
      }
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }, "id": 300, "title": "📊  KPI — Chiffres clés du festival", "type": "row" },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 3, "x": 0, "y": 5 }, "id": 1, "type": "stat",
      "title": "🎬 Films déposés", "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#4EFFCE" }, "unit": "short", "decimals": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS val FROM film", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 3, "x": 3, "y": 5 }, "id": 2, "type": "stat",
      "title": "🎥 Réalisateurs", "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#FF6B6B" }, "unit": "short", "decimals": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(DISTINCT realisator_id) AS val FROM film", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 3, "x": 6, "y": 5 }, "id": 3, "type": "stat",
      "title": "⚖️ Jurés actifs", "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#FFD93D" }, "unit": "short", "decimals": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS val FROM jury WHERE role='jury' AND is_active=1", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 3, "x": 9, "y": 5 }, "id": 4, "type": "stat",
      "title": "🏆 Finalistes", "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#F97316" }, "unit": "short", "decimals": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS val FROM film WHERE statut='finaliste'", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 3, "x": 12, "y": 5 }, "id": 5, "type": "stat",
      "title": "✅ Films validés", "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#34D399" }, "unit": "short", "decimals": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS val FROM film WHERE statut IN ('valide','selectionne','finaliste')", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 3, "x": 15, "y": 5 }, "id": 6, "type": "stat",
      "title": "💬 Messages", "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#A78BFA" }, "unit": "short", "decimals": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT (SELECT COUNT(*) FROM discussion_message) + (SELECT COUNT(*) FROM global_chat_message) AS val", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 3, "x": 18, "y": 5 }, "id": 7, "type": "stat",
      "title": "🎫 Tickets ouverts", "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "#34D399", "value": null }, { "color": "#FFD93D", "value": 3 }, { "color": "#FF6B6B", "value": 8 }] } } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS val FROM ticket WHERE status='open'", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 3, "x": 21, "y": 5 }, "id": 8, "type": "stat",
      "title": "🤝 Collaborateurs", "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#60A5FA" }, "unit": "short", "decimals": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(DISTINCT collaborator_id) AS val FROM collaborator_film", "format": "table", "refId": "A" }] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 301, "title": "🔄  Pipeline des candidatures", "type": "row" },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 8, "w": 10, "x": 0, "y": 10 }, "id": 10, "type": "barchart",
      "title": "Entonnoir — Films par statut",
      "options": { "barRadius": 0.15, "barWidth": 0.7, "groupWidth": 0.7, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "orientation": "horizontal", "tooltip": { "mode": "single", "sort": "none" }, "xTickLabelSpacing": 100 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80, "lineWidth": 0 }, "unit": "short", "min": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT CASE statut WHEN 'soumis' THEN '📥 Soumis' WHEN 'to_review' THEN '🔍 À examiner' WHEN 'in_discussion' THEN '💬 En discussion' WHEN 'asked_to_modify' THEN '✏️ Modif demandée' WHEN 'arevoir' THEN '🔄 À revoir' WHEN 'valide' THEN '✅ Validé' WHEN 'selectionne' THEN '⭐ Sélectionné' WHEN 'finaliste' THEN '🏆 Finaliste' WHEN 'refuse' THEN '❌ Refusé' ELSE statut END AS Statut, COUNT(*) AS Films FROM film GROUP BY statut ORDER BY FIELD(statut,'finaliste','selectionne','valide','arevoir','in_discussion','asked_to_modify','to_review','soumis','refuse')", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 7, "x": 10, "y": 10 }, "id": 11, "type": "gauge",
      "title": "Taux de validation", "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percent", "min": 0, "max": 100, "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "#FF6B6B", "value": null }, { "color": "#FFD93D", "value": 25 }, { "color": "#34D399", "value": 50 }] } } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT ROUND(COUNT(CASE WHEN statut IN ('valide','selectionne','finaliste') THEN 1 END)*100.0/COUNT(*),1) AS val FROM film", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 7, "x": 17, "y": 10 }, "id": 12, "type": "gauge",
      "title": "Taux de finalistes", "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percent", "min": 0, "max": 100, "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "#FF6B6B", "value": null }, { "color": "#FFD93D", "value": 10 }, { "color": "#34D399", "value": 20 }] } } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT ROUND(COUNT(CASE WHEN statut='finaliste' THEN 1 END)*100.0/COUNT(*),1) AS val FROM film", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 7, "x": 10, "y": 14 }, "id": 13, "type": "gauge",
      "title": "Taux de refus", "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percent", "min": 0, "max": 100, "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "#34D399", "value": null }, { "color": "#FFD93D", "value": 20 }, { "color": "#FF6B6B", "value": 40 }] } } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT ROUND(COUNT(CASE WHEN statut='refuse' THEN 1 END)*100.0/COUNT(*),1) AS val FROM film", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 7, "x": 17, "y": 14 }, "id": 14, "type": "stat",
      "title": "🎞️ Films sans vidéo uploadée", "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "#34D399", "value": null }, { "color": "#FFD93D", "value": 5 }, { "color": "#FF6B6B", "value": 15 }] } } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT COUNT(*) AS val FROM film WHERE video_url IS NULL OR video_url=''", "format": "table", "refId": "A" }] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }, "id": 302, "title": "🤖  Analyse Intelligence Artificielle", "type": "row" },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 8, "w": 6, "x": 0, "y": 19 }, "id": 20, "type": "piechart",
      "title": "Full IA vs Hybride",
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "values": ["value","percent"] }, "pieType": "donut", "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT CASE ia_class WHEN 'full' THEN '🤖 Full IA' ELSE '🔀 Hybride' END AS Classe, COUNT(*) AS Films FROM film GROUP BY ia_class", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 8, "w": 9, "x": 6, "y": 19 }, "id": 21, "type": "barchart",
      "title": "Outils IA utilisés dans les films",
      "options": { "barRadius": 0.15, "barWidth": 0.65, "groupWidth": 0.7, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "orientation": "horizontal", "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#4EFFCE" }, "custom": { "fillOpacity": 80, "lineWidth": 0 }, "unit": "short", "min": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT '🖼️ Image IA' AS Outil, SUM(ia_image) AS Films FROM film UNION ALL SELECT '🎵 Son IA', SUM(ia_son) FROM film UNION ALL SELECT '📝 Scénario IA', SUM(ia_scenario) FROM film UNION ALL SELECT '🎬 Post-prod IA', SUM(ia_post) FROM film ORDER BY Films DESC", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 9, "x": 15, "y": 19 }, "id": 22, "type": "stat",
      "title": "Durée moyenne des films", "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#A78BFA" }, "unit": "short", "decimals": 1, "displayName": "minutes" } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT ROUND(AVG(duration)/60.0,1) AS val FROM film WHERE duration IS NOT NULL AND duration>0", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 9, "x": 15, "y": 23 }, "id": 23, "type": "barchart",
      "title": "Sous-titres disponibles",
      "options": { "barRadius": 0.2, "barWidth": 0.5, "groupWidth": 0.6, "legend": { "showLegend": false }, "orientation": "auto", "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80, "lineWidth": 0 }, "unit": "short", "min": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT '🇫🇷 Sous-titres FR' AS Type, COUNT(*) AS Films FROM film WHERE subtitle_fr_url IS NOT NULL AND subtitle_fr_url!='' UNION ALL SELECT '🇬🇧 Sous-titres EN', COUNT(*) FROM film WHERE subtitle_en_url IS NOT NULL AND subtitle_en_url!='' UNION ALL SELECT '❌ Aucun sous-titre', COUNT(*) FROM film WHERE (subtitle_fr_url IS NULL OR subtitle_fr_url='') AND (subtitle_en_url IS NULL OR subtitle_en_url='')", "format": "table", "refId": "A" }] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 303, "title": "🌍  Géographie & Profil des réalisateurs", "type": "row" },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 9, "w": 9, "x": 0, "y": 28 }, "id": 30, "type": "barchart",
      "title": "Top 15 pays — Films déposés",
      "options": { "barRadius": 0.15, "barWidth": 0.65, "groupWidth": 0.7, "legend": { "showLegend": false }, "orientation": "horizontal", "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80, "lineWidth": 0 }, "unit": "short", "min": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT r.country AS Pays, COUNT(f.id) AS Films FROM film f JOIN realisator r ON r.id=f.realisator_id GROUP BY r.country ORDER BY COUNT(f.id) DESC LIMIT 15", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 5, "w": 7, "x": 9, "y": 28 }, "id": 31, "type": "piechart",
      "title": "Genre des réalisateurs",
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value","percent"] }, "pieType": "pie", "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT CASE WHEN LOWER(gender) IN ('m','male','homme','h') THEN '👨 Homme' WHEN LOWER(gender) IN ('f','female','femme') THEN '👩 Femme' ELSE '⚧ Autre/ND' END AS Genre, COUNT(*) AS Nombre FROM realisator GROUP BY Genre ORDER BY Nombre DESC", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 5, "w": 8, "x": 16, "y": 28 }, "id": 32, "type": "gauge",
      "title": "Taux abonnement newsletter",
      "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percent", "min": 0, "max": 100, "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "#FF6B6B", "value": null }, { "color": "#FFD93D", "value": 30 }, { "color": "#34D399", "value": 60 }] } } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT ROUND(SUM(newsletter)*100.0/COUNT(*),1) AS val FROM realisator", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 7, "x": 9, "y": 33 }, "id": 33, "type": "barchart",
      "title": "Présence sur les réseaux sociaux",
      "options": { "barRadius": 0.2, "barWidth": 0.6, "groupWidth": 0.6, "legend": { "showLegend": false }, "orientation": "auto", "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80, "lineWidth": 0 }, "unit": "short", "min": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT '▶️ YouTube' AS Réseau, COUNT(*) AS Réalisateurs FROM realisator WHERE youtube IS NOT NULL AND youtube!='' UNION ALL SELECT '📸 Instagram', COUNT(*) FROM realisator WHERE instagram IS NOT NULL AND instagram!='' UNION ALL SELECT '💼 LinkedIn', COUNT(*) FROM realisator WHERE linkedin IS NOT NULL AND linkedin!='' UNION ALL SELECT '📘 Facebook', COUNT(*) FROM realisator WHERE facebook IS NOT NULL AND facebook!='' UNION ALL SELECT '🐦 X/Twitter', COUNT(*) FROM realisator WHERE xtwitter IS NOT NULL AND xtwitter!='' ORDER BY Réalisateurs DESC", "format": "table", "refId": "A" }] },

    { "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "gridPos": { "h": 4, "w": 8, "x": 16, "y": 33 }, "id": 34, "type": "barchart",
      "title": "Comment ont-ils découvert le festival ?",
      "options": { "barRadius": 0.2, "barWidth": 0.6, "groupWidth": 0.6, "legend": { "showLegend": false }, "orientation": "horizontal", "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#FFD93D" }, "custom": { "fillOpacity": 80, "lineWidth": 0 }, "unit": "short", "min": 0 } },
      "targets": [{ "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" }, "rawSql": "SELECT how_did_you_know_us AS Source, COUNT(*) AS Nombre FROM realisator WHERE how_did_you_know_us IS NOT NULL AND how_did_you_know_us!='' GROUP BY how_did_you_know_us ORDER BY COUNT(*) DESC LIMIT 8", "format": "table", "refId": "A" }] },

