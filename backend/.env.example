PORT=5500

# Base de données MySQL
# En local : 127.0.0.1 (MAMP/WAMP port 8889) | localhost (MySQL standard port 3306)
# Avec Docker : mysql (nom du service docker-compose)
DB_HOST=127.0.0.1
DB_PORT=8889
DB_NAME=marsai
DB_USER=root
DB_PASSWORD=root

# MinIO (stockage objet S3-compatible, auto-hébergé)
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=marsai
MINIO_REGION=us-east-1
MINIO_FOLDER=grp1

# JWT & Auth
JWT_SECRET=change-this-secret
GOOGLE_CLIENT_ID=

# Email (Gmail SMTP)
EMAIL_USER=
EMAIL_PASS=

# Frontend (pour les liens d'invitation)
FRONTEND_URL=http://localhost:5173

# YouTube Data API v3 (OAuth2)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
