#!/usr/bin/env bash

set -u

INPUT_VIDEO="video-test.mp4"
OUTPUT_IMAGE="poster.webp"
FFMPEG_SEEK="00:00:05"
SAMPLE_INTERVAL="0.2"

if ! command -v ffmpeg >/dev/null 2>&1; then
	echo "Erreur: ffmpeg est introuvable dans le PATH."
	exit 1
fi

if [[ ! -f "$INPUT_VIDEO" ]]; then
	echo "Erreur: fichier introuvable: $INPUT_VIDEO"
	exit 1
fi

format_duration() {
	local total_ms="$1"
	local minutes seconds milliseconds
	minutes=$(( total_ms / 60000 ))
	seconds=$(( (total_ms % 60000) / 1000 ))
	milliseconds=$(( total_ms % 1000 ))
	printf "%02d:%02d.%03d" "$minutes" "$seconds" "$milliseconds"
}

start_ms=$(date +%s%3N)
echo "script lancer"
echo "commande: ffmpeg -ss $FFMPEG_SEEK -i $INPUT_VIDEO -frames:v 1 $OUTPUT_IMAGE"

ffmpeg -ss "$FFMPEG_SEEK" -i "$INPUT_VIDEO" -frames:v 1 "$OUTPUT_IMAGE" >/dev/null 2>&1 &
ffmpeg_pid=$!

peak_rss_kb=0

# Ecouteur: surveille la RAM du process ffmpeg pendant son execution.
while kill -0 "$ffmpeg_pid" >/dev/null 2>&1; do
	current_rss_kb=$(ps -o rss= -p "$ffmpeg_pid" 2>/dev/null | tr -d ' ')
	if [[ -n "${current_rss_kb:-}" ]] && [[ "$current_rss_kb" =~ ^[0-9]+$ ]]; then
		if (( current_rss_kb > peak_rss_kb )); then
			peak_rss_kb=$current_rss_kb
		fi
	fi
	sleep "$SAMPLE_INTERVAL"
done

wait "$ffmpeg_pid"
ffmpeg_exit_code=$?

end_ms=$(date +%s%3N)
duration_ms=$(( end_ms - start_ms ))
duration_human=$(format_duration "$duration_ms")
peak_rss_mb=$(awk "BEGIN { printf \"%.2f\", $peak_rss_kb / 1024 }")

if [[ "$ffmpeg_exit_code" -eq 0 ]]; then
	echo "script fini"
	echo "statut: succes"
else
	echo "script fini"
	echo "statut: echec (code $ffmpeg_exit_code)"
fi

echo "duree: ${duration_human} (${duration_ms} ms)"
echo "ram max: ${peak_rss_kb} KB (${peak_rss_mb} MB)"

exit "$ffmpeg_exit_code"
