FROM node:20-alpine

WORKDIR /app

# Copier uniquement les fichiers de dépendances
COPY package.json package-lock.json ./

# Installer les dépendances (npm ci = lockfile strict, plus rapide)
RUN npm ci

# Le code source sera monté via bind mount (pas COPY)
# → hot reload garanti

EXPOSE 5173

CMD ["npm", "run", "dev"]
